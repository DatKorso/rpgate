{
	"name": "rpgate",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check app components lib db env.ts vitest.config.ts",
		"format": "biome check --write app components lib db env.ts vitest.config.ts",
		"test": "vitest --run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push"
	},
	"dependencies": {
		"@radix-ui/react-avatar": "^1.1.10",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.44.6",
		"lucide-react": "^0.545.0",
		"next": "^14.2.5",
		"pg": "^8.12.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tailwind-merge": "^3.3.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@tailwindcss/typography": "^0.5.19",
		"@types/node": "^20.11.30",
		"@types/pg": "^8.15.5",
		"@types/react": "19.2.2",
		"@vitest/ui": "^3.2.4",
		"autoprefixer": "^10.4.21",
		"drizzle-kit": "^0.31.5",
		"postcss": "^8.5.6",
		"tailwindcss": "^3.4.18",
		"typescript": "^5.6.2",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=18.17.0"
	}
}
