# Database connection string (PostgreSQL with pgvector extension)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# OpenRouter API key for LLM (Grok-4-fast)
OPENROUTER_API_KEY=your_openrouter_key

# AITunnel API key for embeddings (required for Personal Memory System)
# Get your key at: https://aitunnel.ru
# Used for text-embedding-v4 model (1024 dimensions)
AITUNNEL_API_KEY=your_aitunnel_key

# Admin API key for feature flags management (optional)
# If not set, admin endpoints will be accessible without authentication (dev mode)
ADMIN_API_KEY=your_admin_api_key

